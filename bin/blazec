#!/usr/bin/env bun
// @ts-nocheck

import { parseArgs } from "node:util";
import Compiler from "../lib/compiler/Compiler.ts";
import CompilerTransactionBuilder from "../lib/compiler/CompilerTransactionBuilder.ts";
import { exit } from "node:process";
import path from "node:path";
import chalk from "chalk";

const argv0 = path.basename(process.argv[1]);

function usage() {
    console.log("Usage:");
    console.log("  %s [OPTION]... [FILE]...", argv0);
}

const positionals: string[] = [];
const values: Record<string, string> = {};

try {
    const { positionals: _positionals, values: _values } = parseArgs({
        args: process.argv.slice(2),
        allowPositionals: true,
        strict: true,
        options: {
            help: {
                type: "boolean",
                short: "h"
            },
            output: {
                type: "string",
                short: "o"
            }
        }
    });

    positionals.push(..._positionals);
    Object.assign(values, _values);
} catch (error) {
    if (
        error instanceof TypeError &&
        "code" in error &&
        error.code &&
        typeof error.code === "string" &&
        error.code.startsWith("ERR_PARSE_ARGS_")
    ) {
        console.error(
            chalk.white.bold(argv0 + ": ") +
                chalk.red.bold("error: ") +
                chalk.white(error.message)
        );

        exit(1);
    }

    throw error;
}

if (values.help) {
    usage();
    exit(0);
}

const compiler = new Compiler();
const tx = new CompilerTransactionBuilder()
    .addInputFiles(...positionals)
    .setOutputFile(values.output ?? "out.js")
    .build();

if (await compiler.accept(tx) === undefined) {
    exit(1);
}
